---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('posts')).filter((post) => !post.data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} - Chris Jarling`}>
	{post.data.link ? (
		<a href={post.data.link} target="_blank" rel="noopener">
			<h1 class="text-4xl font-bold mb-2 text-blue-400 dark:text-blue-300">{post.data.title} &rarr;</h1>
		</a>
	) : (
		<h1 class="text-4xl font-bold mb-2">{post.data.title}</h1>
	)}
	<a href={`/posts/${post.id}`} class="text-sm text-gray-500 dark:text-gray-400 hover:text-gray-950 dark:hover:text-white transition-colors">
		<time class="mb-8 block">
			{new Date(post.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
		</time>
	</a>
	<article class="prose prose-lg md:prose-base dark:prose-invert max-w-none">
		<Content />
	</article>
</Base>
